{
  "name": "testes-com-bancos-de-dados",
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "cross-env DB_NAME=customers node src/index.js",
    "dev": "cross-env DB_NAME=customers node --watch src/index.js",
    "test": "cross-env NODE_ENV=test node --experimental-test-coverage --test test/api.test.js",
    "test:dev": "cross-env NODE_ENV=test node --watch --test test/api.test.js",
    "test:debug": "cross-env NODE_ENV=test node --inspect --test --watch test/api.test.js",
    "infra:up": "docker compose up -d --build",
    "infra:up:db": "docker compose up mongodb -d",
    "infra:down": "docker compose down --volumes"
  },
  "keywords": [],
  "author": "marceloaraujo",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "fastify": "^5.7.4",
    "mongodb": "^7.1.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
